{
  "routes": [
    {
      "route": "/login",
      "redirect": "/.auth/login/google?post_login_redirect_uri=/app.html"
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout?post_logout_redirect_uri=/"
    },
    {
      "route": "/app.html",
      "allowedRoles": ["authenticated"]
    }
  ]
}
{
  "routes": [
    {
      "route": "/",
      "rewrite": "/index.html"
    },
    {
      "route": "/app",
      "rewrite": "/app.html"
    },
    {
      "route": "/chat",
      "rewrite": "/chat.html"
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout?post_logout_redirect_uri=/"
    },
    {
      "route": "/login",
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/app.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/app.html", "/chat.html", "/*.{css,js,png,jpg,svg,ico}"]
  },
  "responseOverrides": {
    "401": {
      "redirect": "/"
    },
    "403": {
      "redirect": "/"
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "X-XSS-Protection": "1; mode=block"
  }
}
